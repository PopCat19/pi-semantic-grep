{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**",
			"!node_modules",
			"!dist",
			"!coverage",
			"!package-lock.json"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noConstantCondition": "off",
				"noUnusedVariables": "warn",
				"noUnusedImports": "warn",
				"noUndeclaredVariables": "off",
				"useParseIntRadix": "warn"
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"noDoubleEquals": "warn",
				"noBitwiseOperators": "off",
				"noGlobalIsNan": "warn",
				"noEmptyBlockStatements": "warn",
				"noTemplateCurlyInString": "warn",
				"noEvolvingTypes": "warn",
				"noImplicitAnyLet": "warn",
				"useIterableCallbackReturn": "warn"
			},
			"complexity": {
				"useLiteralKeys": "warn",
				"noBannedTypes": "warn",
				"noUselessTernary": "warn",
				"noStaticOnlyClass": "warn"
			},
			"style": {
				"noNonNullAssertion": "off",
				"useTemplate": "warn",
				"useImportType": "off",
				"useExponentiationOperator": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	}
}
